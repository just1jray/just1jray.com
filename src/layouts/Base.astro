---
interface Props {
  title?: string;
}

const { title = "Just 1 J. Ray" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/knight.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Just 1 J. Ray — human // nerd" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <img src="/knight.svg" alt="" id="bg-emblem" />
    <main>
      <slot />
    </main>
    <script is:inline>
      var el = document.getElementById('bg-emblem');
      if (el) {
        function show() { el.style.opacity = '0.1'; }
        if (el.complete) show();
        else el.onload = show;
      }
    </script>
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    background: #0a0a0a;
    color: #e5e5e5;
    font-family: ui-monospace, "Cascadia Code", "Source Code Pro", Menlo,
      Consolas, "DejaVu Sans Mono", monospace;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100dvh;
    padding: 1.5rem;
  }

  main {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 600px;
  }

  a {
    color: #e5e5e5;
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  a:hover {
    opacity: 0.6;
  }

  #bg-emblem {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 300px;
    height: 300px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 1.5s ease;
  }
</style>
