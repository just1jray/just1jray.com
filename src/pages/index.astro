---
import Base from "../layouts/Base.astro";
import LinkGroup from "../components/LinkGroup.astro";

const socials = [
  { label: "github", href: "https://github.com/just1jray" },
  { label: "twitter/x", href: "https://x.com/just1jray" },
  { label: "instagram", href: "https://instagram.com/just1jray" },
  { label: "youtube", href: "https://youtube.com/@just1jray" },
];

const projects = [
  { label: "dots", href: "https://github.com/just1jray/dots" },
  { label: "rAI3DS", href: "https://github.com/just1jray/rAI3DS" },
];
---

<Base>
  <h1>Just 1 J. Ray</h1>
  <p class="tagline">human <span class="orange">//</span> nerd</p>

  <div class="links">
    <LinkGroup title="socials" links={socials} />
    <LinkGroup title="projects" links={projects} />
  </div>
</Base>

<style>
  h1 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .tagline {
    color: #737373;
    font-size: 0.875rem;
    margin-bottom: 3rem;
  }

  .tagline .orange {
    color: #f7931a;
  }

  .links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
</style>
